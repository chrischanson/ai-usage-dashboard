# .bazelrc
# Uploads build & test results to BuildBuddy for browser inspection.
# HOST_IP is substituted by setup.sh at deploy time.
# Results UI: http://HOST_IP_PLACEHOLDER:8080

build --bes_results_url=http://HOST_IP_PLACEHOLDER:8080/invocation/
build --bes_backend=grpc://HOST_IP_PLACEHOLDER:1985
build --remote_cache=grpc://HOST_IP_PLACEHOLDER:1985

# Show test output for failures only
test --test_output=errors

# Use Clang as the default C++ compiler
build --action_env=CC=clang
build --action_env=CXX=clang++

# Bazel 9: auto-load C++ rules for third-party deps that haven't migrated yet
common --incompatible_autoload_externally=+cc_library,+cc_binary,+cc_test,+cc_proto_library,+cc_shared_library

