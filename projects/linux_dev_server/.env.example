# ── API Keys ──────────────────────────────────────────────────
# Required: OpenRouter API key for AI coding agents
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Default model for Claude Code (OpenRouter ID)
ANTHROPIC_MODEL=anthropic/claude-3.5-sonnet

# Optional: OpenCode Zen API key (leave blank if not using)
OPENCODE_ZEN_API_KEY=

# Optional: Codex CLI — by default it reuses OPENROUTER_API_KEY.
# Override with a real OpenAI key + base URL to use official OpenAI models:
# CODEX_OPENAI_BASE_URL=https://api.openai.com/v1
# (leave blank to route Codex through OpenRouter like everything else)
CODEX_OPENAI_BASE_URL=

# ── Gitea Configuration ──────────────────────────────────────
# Admin account created automatically on first run
GITEA_ADMIN_USER=dev
GITEA_ADMIN_PASSWORD=changeme123
GITEA_ADMIN_EMAIL=dev@localhost

# ── Git Identity (used inside the dev container) ─────────────
GIT_USER_NAME=Dev User
GIT_USER_EMAIL=dev@localhost
