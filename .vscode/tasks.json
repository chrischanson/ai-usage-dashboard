{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bazel Build",
      "type": "shell",
      "command": "bazel build //...",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Bazel Build Debug hello_test",
      "type": "shell",
      "command": "bazel build -c dbg --strip=never //projects/hello_world:hello_test",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Bazel Build Debug hello_world",
      "type": "shell",
      "command": "bazel build -c dbg --strip=never //projects/hello_world:hello_world",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Bazel Run",
      "type": "shell",
      "command": "bazel run //${input:target}",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Bazel Test",
      "type": "shell",
      "command": "bazel test //...",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Bazel Clean",
      "type": "shell",
      "command": "bazel clean --expunge",
      "group": "build",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "target",
      "type": "promptString",
      "description": "Bazel target to run (e.g. //src:main)"
    }
  ]
}
