{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug hello_test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bazel-bin/projects/hello_world/hello_test",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "sourceFileMap": {
                "/proc/self/cwd": "${workspaceFolder}"
            },
            "preLaunchTask": "Bazel Build Debug hello_test"
