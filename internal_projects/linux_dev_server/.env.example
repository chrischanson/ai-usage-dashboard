# ── API Keys ──────────────────────────────────────────────────
# Required: OpenRouter API key for AI coding agents
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenCode Zen API key (leave blank if not using)
OPENCODE_ZEN_API_KEY=

# Optional: Real OpenAI API key — used by Codex CLI.
# If set, Codex uses this key instead of OPENROUTER_API_KEY.
# Required when CODEX_OPENAI_BASE_URL points to api.openai.com.
OPENAI_API_KEY=

# Optional: Codex base URL — defaults to OpenRouter.
# Set to https://api.openai.com/v1 to use real OpenAI (requires OPENAI_API_KEY above).
CODEX_OPENAI_BASE_URL=

# ── Gitea Configuration ──────────────────────────────────────
# Admin account created automatically on first run
GITEA_ADMIN_USER=dev
GITEA_ADMIN_PASSWORD=changeme123
GITEA_ADMIN_EMAIL=dev@localhost

# ── Git Identity (used inside the dev container) ─────────────
GIT_USER_NAME=Dev User
GIT_USER_EMAIL=dev@localhost

# ── Tailscale ────────────────────────────────────────────────
# Optional: Tailscale auth key for headless login.
# Generate at https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gemini CLI ───────────────────────────────────────────────
# Optional: Gemini API key for headless mode (no browser login).
# Generate at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
